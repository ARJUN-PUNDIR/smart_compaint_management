      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"title\": \"Pipe Burst on Main Street\",\n  \"description\": \"There is a massive water leak happening right now. The road is flooding.\",\n  \"category\": \"Water\",\n  \"location\": \"Main Street\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/complaints",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints"]
            }
          }
        },
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/complaints",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints"]
            }
          }
        },
        {
          "name": "Search Complaints",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/complaints/search?location=Main Street",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "complaints", "search"],
              "query": [
                { "key": "location", "value": "Main Street" }
              ]
            }
          }
        },
        {
          "name": "Update Complaint Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/complaints/COMPLAINT_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
